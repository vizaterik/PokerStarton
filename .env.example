# Local without Docker (default):
DATABASE_URL=sqlite:///./pokerledger.db
# Or PostgreSQL:
# DATABASE_URL=postgresql+psycopg://pokerledger:pokerledger@localhost:5432/pokerledger
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173
UPLOAD_DIR=uploads
# Google Cloud Console → OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins: http://localhost:5173
GOOGLE_CLIENT_ID=
# Email verification (required for real inbox delivery)
# Gmail: enable 2FA → App password → https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM=PokerStraton <your@gmail.com>
# SMTP_TLS=true
#
# Yandex:
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_USER=your@yandex.ru
# SMTP_PASSWORD=...
# SMTP_FROM=PokerStraton <your@yandex.ru>
# SMTP_TLS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
